# Copie para .env e preencha. NUNCA commitar .env no Git.
# cp .env.example .env

# ─── Provider de LLM ────────────────────────────────────────────────────────
# Escolha 1 provider e descomente a linha correspondente.

# Opção A — Gemini (recomendado: free tier, melhor para PT-BR)
GEMINI_API_KEY=sua-chave-aqui

# Opção B — OpenAI ($5 free credit)
# OPENAI_API_KEY=sk-substitua

# ─── Modelos ─────────────────────────────────────────────────────────────────
# LLM para queries simples (routing cheap-first)
CHEAP_MODEL=gemini-2.0-flash
# LLM para queries complexas (análise, comparação)
PREMIUM_MODEL=gemini-2.5-pro
# Modelo usado pelo pipeline.answer() diretamente
LLM_MODEL=gemini-2.0-flash

# Modelo de embedding (deve ser do mesmo provider que a API key acima)
# Gemini:  text-embedding-004
# OpenAI:  text-embedding-3-small
EMBED_MODEL=text-embedding-004

# ─── Opcional: Langfuse observabilidade ──────────────────────────────────────
# Descomente se for usar Langfuse Cloud para rastrear chamadas
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
